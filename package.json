		"@types/bun": "^1.3.13",
		"drizzle-kit": "^0.31.10",
		"husky": "^9.1.7",
		"turbo": "^2.9.6",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.13",
	"workspaces": [
		"apps/*",
		"packages/*"
